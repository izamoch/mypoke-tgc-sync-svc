# Cloudflare Worker endpoint exposing the D1 sync API (POST {WORKER_URL}/sync/update)
WORKER_URL=https://your-worker.example.workers.dev

# Shared secret sent as the X-API-Key header to authenticate against the Worker
ADMIN_TOKEN=changeme

# Optional: local sync-state database (defaults to sqlite:///./data/poke_tgc.sqlite)
# DATABASE_URL=sqlite:///./data/poke_tgc.sqlite

# Optional: webhook to receive markdown/HTML sync reports after each run
# REPORT_WEBHOOK_URL=https://example.com/webhook
