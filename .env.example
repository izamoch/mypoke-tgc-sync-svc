# Cloudflare account ID (Dashboard -> Workers & Pages -> Overview, right sidebar)
CLOUDFLARE_ACCOUNT_ID=your-account-id

# API token with D1:Edit permission, scoped to the database below
CLOUDFLARE_API_TOKEN=your-d1-api-token

# Cloudflare D1 database ID (wrangler d1 list)
D1_DATABASE_ID=your-d1-database-id

# Optional: webhook to receive markdown/HTML sync reports after each run
# REPORT_WEBHOOK_URL=https://example.com/webhook
